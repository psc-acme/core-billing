{
    "name": "psc-acme/core-billing",
    "description": "Package core-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\CoreBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "nette/utils": "^4.0",
        "symfony/routing": "^7.0",
        "psr/event-dispatcher": "^1.0",
        "symfony/symfony": "^6.3",
        "doctrine/doctrine-bundle": "^2.13",
        "symfony/http-kernel": "^6.2"
    },
    "require-dev": {
        "infection/infection": "^0.27",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}